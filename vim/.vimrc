" Основное
syntax on
set number
set encoding=utf-8

" Отступы (YAML/Ansible)
set tabstop=2
set shiftwidth=2
set expandtab
set autoindent

" Поиск
set hlsearch
set incsearch
set ignorecase

" Мышь + буфер
set mouse=a
set clipboard=unnamedplus

" Удобства
set noswapfile
set pastetoggle=<F2>

nnoremap <F3> :set number!<CR>
